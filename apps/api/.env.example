# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/jscraft_db?schema=public"

# ─── Redis (optional — for caching) ─────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT Secrets — generate with: openssl rand -hex 64 ───────────────────────
JWT_ACCESS_SECRET="replace-with-64-char-random-string-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
JWT_REFRESH_SECRET="replace-with-different-64-char-random-string-xxxxxxxxxxxxxxxxxxxxx"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"

# ─── Email (Resend / SMTP) ───────────────────────────────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS="re_your_api_key"
SMTP_FROM="noreply@jscraft.dev"

# ─── Cloudinary (avatar uploads) ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Anthropic AI ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── Security ────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
